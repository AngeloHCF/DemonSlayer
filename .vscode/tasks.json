{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build DemonSlayer",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "src/main.cpp", "src/game.cpp", "src/player.cpp",
                "src/enemy.cpp", "src/boss.cpp", "src/effects.cpp",
                "src/combat.cpp", "src/audio.cpp", "src/companion.cpp",
                "src/shinobu.cpp", "src/rengoku.cpp",
                "src/gyomei.cpp", "src/tengen.cpp",
                "src/akaza.cpp", "src/moons.cpp", "src/sanemi.cpp",
                "-o", "demonslayer.exe",
                "-std=c++17", "-O2",
                "-lraylib", "-lglfw3", "-lopengl32", "-lgdi32", "-lwinmm",
                "-static-libgcc", "-static-libstdc++"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"]
        }
    ]
}
